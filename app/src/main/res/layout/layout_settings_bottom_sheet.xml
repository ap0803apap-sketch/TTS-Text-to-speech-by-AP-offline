<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true">

        <com.google.android.material.bottomsheet.BottomSheetDragHandleView
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="20dp"/>

        <!-- Theme Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_pallate"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorPrimary"/>

                <RadioGroup
                    android:id="@+id/themeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/themeSystem"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="System Default" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/themeLight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Light" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/themeDark"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Dark" />
                </RadioGroup>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/dynamicColorSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dynamic Colors"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:layout_marginTop="12dp"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/amoledSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AMOLED Black"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Security Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Security"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_security"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorPrimary"/>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/bsBiometricSwitch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:text="Require Biometric Lock"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_fingerprint"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorOnSurface"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Developer Info Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Developer Info"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_info"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorPrimary"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Name: AP"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorOnSurface"/>

                <TextView
                    android:id="@+id/devEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email: ap0803apap@gmail.com"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:textColor="?attr/colorPrimary"
                    android:drawableStart="@drawable/ic_email"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorPrimary"/>

                <TextView
                    android:id="@+id/githubLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GitHub: https://github.com/ap0803apap-sketch/"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:layout_marginTop="12dp"
                    android:autoLink="web"
                    android:gravity="center_vertical"
                    android:drawableStart="@drawable/ic_link"
                    android:drawablePadding="16dp"
                    app:drawableTint="?attr/colorPrimary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- License Info Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/licenseCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/licenseHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        app:tint="?attr/colorPrimary"
                        android:contentDescription="@string/license_info_title" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="@string/license_info_title"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/licenseExpandIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="?attr/colorPrimary"
                        android:contentDescription="Expand" />
                </LinearLayout>

                <TextView
                    android:id="@+id/licenseText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/license_content"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>